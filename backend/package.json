{
  "name": "campuslink-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch server/src/server.ts",
    "build": "tsc -p tsconfig.server.json",
    "start": "node server/dist/server.js",
